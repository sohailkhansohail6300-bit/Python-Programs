
import string
import itertools

password=input('Enter password must be in char : ')
pass_crack=string.ascii_lowercase
attempts=0
while True:
    lenght=int(input('input password lenght : '))
    for i in itertools.product(pass_crack,repeat=lenght):
        pass_guess=''.join(i)
        attempts+=1
        if pass_guess==password:
            print(f'Crack password is : {pass_guess}')
            print(f'password attempts is : {attempts}')
            exit()
    else:
        print(f'again try password lenght {lenght}')
