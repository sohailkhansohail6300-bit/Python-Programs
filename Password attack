import string

password=input('Enter 4 charecter password :')
pass_attack=string.ascii_lowercase
attemps=0
for i in pass_attack:
    for i1 in pass_attack:
        for i2 in pass_attack:
            for i3 in pass_attack:
                guess_pass=i+i1+i2+i3
                attemps+=1
                if guess_pass==password:
                    print(f'password is : {guess_pass} and attempts are : {attemps}')
                    exit()

